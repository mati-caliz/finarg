# JWT (opcional; hay valor por defecto en application.yml)
JWT_SECRET=

# Email (opcional; solo si necesitás enviar emails)
MAIL_USERNAME=
MAIL_PASSWORD=

# Google OAuth: mismo Client ID que en el frontend
# Requerido para que funcione POST /api/v1/auth/google
# Ver README sección "Login con Google" para obtenerlo.
GOOGLE_CLIENT_ID=
