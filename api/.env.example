# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finarg
DB_USERNAME=finarg
DB_PASSWORD=your_database_password

# Hibernate Configuration
HIBERNATE_DDL_AUTO=validate
HIBERNATE_SHOW_SQL=false

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Configuration (REQUIRED - Generate a secure random key for production)
JWT_SECRET=your_jwt_secret_key_here

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# Feedback Notification (Optional - email to receive feedback notifications)
FEEDBACK_NOTIFICATION_EMAIL=feedback@finarg.com

# Google OAuth
GOOGLE_CLIENT_ID=340703442600-gigg7doav8llkjfaaq7feumfcmfg2eug.apps.googleusercontent.com

# Logging (Production recommended: INFO for both)
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# Investment APIs
FINNHUB_API_KEY=d688749r01qi2if75h5gd688749r01qi2if75h60
METALS_API_KEY=your_metals_api_key_here

# Web Scraper Configuration
# Proxies for rotation (comma-separated list, format: host:port or http://host:port)
# Example: SCRAPER_PROXIES=proxy1.example.com:8080,proxy2.example.com:8080,proxy3.example.com:8080
# Leave empty to run without proxies
SCRAPER_PROXIES=
