# API del backend (por defecto: http://localhost:8080/api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Google OAuth: Client ID para "Iniciar sesión con Google"
# Sin este valor el botón de Google no se muestra en login/registro.
# Ver README sección "Login con Google" para obtenerlo.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
